{
	"expo": {
		"name": "Para Code",
		"slug": "para-code-mobile",
		"scheme": "paracode-mobile",
		"version": "0.1.0",
		"icon": "./assets/icon.png",
		"orientation": "portrait",
		"userInterfaceStyle": "dark",
		"newArchEnabled": true,
		"ios": {
			"supportsTablet": false,
			"bundleIdentifier": "ltd.paradis.paracode.mobile",
			"appleTeamId": "WB4G82C384",
			"infoPlist": {
				"NSCameraUsageDescription": "QRコードでPara Codeとペアリングするためにカメラを使用します。",
				"ITSAppUsesNonExemptEncryption": false,
				"UIBackgroundModes": ["remote-notification"],
				"NSSupportsLiveActivities": true,
				"NSMicrophoneUsageDescription": "このアプリはマイクを使用しません（画面ミラー受信ライブラリが参照するため記載しています）。"
			}
		},
		"plugins": [
			"expo-router",
			[
				"@sentry/react-native/expo",
				{
					"organization": "maguro-bot-corp",
					"project": "para-code-mobile",
					"url": "https://sentry.io/"
				}
			],
			"expo-secure-store",
			"expo-notifications",
			[
				"expo-camera",
				{ "cameraPermission": "QRコードでPara Codeとペアリングするためにカメラを使用します。" }
			],
			[
				"expo-image-picker",
				{ "photosPermission": "エージェントへ画像を添付するためにフォトライブラリを使用します。" }
			],
			[
				"expo-local-authentication",
				{ "faceIDPermission": "アプリのロック解除にFace IDを使用します。" }
			]
		]
	}
}
