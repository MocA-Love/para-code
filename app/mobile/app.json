{
	"expo": {
		"name": "Para Code Mobile",
		"slug": "para-code-mobile",
		"scheme": "paracode-mobile",
		"version": "0.1.0",
		"icon": "./assets/icon.png",
		"orientation": "portrait",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"supportsTablet": false,
			"bundleIdentifier": "ltd.paradis.paracode.mobile",
			"appleTeamId": "WB4G82C384",
			"infoPlist": {
				"NSCameraUsageDescription": "QRコードでPara Codeとペアリングするためにカメラを使用します。",
				"ITSAppUsesNonExemptEncryption": true
			}
		},
		"plugins": [
			"expo-router",
			"expo-secure-store",
			[
				"expo-camera",
				{ "cameraPermission": "QRコードでPara Codeとペアリングするためにカメラを使用します。" }
			]
		]
	}
}
