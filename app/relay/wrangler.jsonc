{
	// PARA-CODE: fork-owned file (Para Code) — Para Code Mobile relay worker
	"name": "para-mobile-relay",
	"main": "src/worker.ts",
	"compatibility_date": "2024-11-01",
	"compatibility_flags": ["nodejs_compat"],
	"durable_objects": {
		"bindings": [
			{
				"name": "DEVICES",
				"class_name": "DeviceDO"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["DeviceDO"]
		}
	],
	"observability": {
		"enabled": true
	}
}
